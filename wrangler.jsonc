{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "word-whisper",
  "main": "src/cloudflare/worker.js",
  "compatibility_date": "2026-06-20",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "WORD_WHISPER_ROOM",
        "class_name": "WordWhisperRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "WordWhisperRoom"
      ]
    }
  ]
}
